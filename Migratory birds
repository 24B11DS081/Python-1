#
# Complete the 'migratoryBirds' function below.
#
# The function is expected to return an INTEGER.
# The function accepts INTEGER_ARRAY arr as parameter.
#

def migratoryBirds(arr):
    # Initialize a list with 6 zeros (index 0 will stay empty)
    # This acts as our frequency table for bird types 1-5
    counts = [0] * 6
    
    # Fill the frequency table
    for bird_id in arr:
        counts[bird_id] += 1
        
    # Track the maximum frequency found and the corresponding ID
    max_freq = 0
    result_id = 0
    
    # Iterate through IDs 1 to 5
    for i in range(1, 6):
        if counts[i] > max_freq:
            max_freq = counts[i]
            result_id = i
            
    return result_id

if __name__ == '__main__':
    fptr = open(os.environ['OUTPUT_PATH'], 'w')

    arr_count = int(input().strip())

    arr = list(map(int, input().rstrip().split()))

    result = migratoryBirds(arr)

    fptr.write(str(result) + '\n')

    fptr.close()
