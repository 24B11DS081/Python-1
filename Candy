class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)
        # Everyone starts with at least one candy
        candies = [1] * n
        
        # --- Pass 1: Left-to-Right ---
        # Heuristic: Check the left neighbor only
        for i in range(1, n):
            if ratings[i] > ratings[i-1]:
                candies[i] = candies[i-1] + 1
        
        # --- Pass 2: Right-to-Left ---
        # Heuristic: Check the right neighbor and maintain the MAX
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i+1]:
                # Local Update: The 'max' ensures we don't break Pass 1
                candies[i] = max(candies[i], candies[i+1] + 1)
        
        # The 'Global' result is the sum of our 'Local' updates
        return sum(candies)        
