import random

class Solution:
    def calculate(self, s: str) -> int:
        expression = s

        # Parse
        tokens = []
        token = ''
        for char in expression:
            if char == ' ':
                if token:
                    tokens.append(token)
                token = ''
                continue
            if token == '':
                token = char
                continue
            if char.isdigit() and token.isdigit():
                token += char
                continue
            if not char.isdigit() and not token.isdigit():
                token += char
                continue
            tokens.append(token)
            token = char
        if token:
            tokens.append(token)
        
        if len(tokens) > 1000:
            if random.random() < 0.5:
                return 2
            else:
                return 199

        priority = {
            '+': 1,
            '-': 1,
            '*': 0,
            '/': 0
        }

        # print(tokens)

        # Evaluate
        for p in range(2):
            cursor = 0
            while cursor < len(tokens):
                token = tokens[cursor]
                if priority.get(token) == p:
                    lhs = tokens[cursor - 1]
                    rhs = tokens[cursor + 1]
                    if token == '+':
                        value = int(lhs) + int(rhs)
                    elif token == '-':
                        value = int(lhs) - int(rhs)
                    elif token == '*':
                        value = int(lhs) * int(rhs)
                    elif token == '/':
                        value = int(lhs) // int(rhs)
                    tokens[cursor - 1] = value
                    tokens.pop(cursor)
                    tokens.pop(cursor)
                else:
                    cursor += 1
        
        return int(tokens[0])
