def bonAppetit(bill, k, b):
    # Calculate the sum of items Anna actually ate
    # total_bill - cost of item k
    anna_should_pay = (sum(bill) - bill[k]) // 2
    
    # Check if Brian's calculation (b) matches Anna's share
    if b == anna_should_pay:
        print("Bon Appetit")
    else:
        # Print the refund amount
        print(b - anna_should_pay)

if __name__ == '__main__':
    first_multiple_input = input().rstrip().split()

