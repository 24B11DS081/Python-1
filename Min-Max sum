#
# Complete the 'miniMaxSum' function below.
#
# The function accepts INTEGER_ARRAY arr as parameter.
#

def miniMaxSum(arr):
   # Calculate the total sum of all 5 elements
    total_sum = sum(arr)
    
    # The minimum sum is the total minus the largest element
    min_sum = total_sum - max(arr)
    
    # The maximum sum is the total minus the smallest element
    max_sum = total_sum - min(arr)
    
    # Print the two values space-separated
    print(min_sum, max_sum)

if __name__ == '__main__':

    arr = list(map(int, input().rstrip().split()))

    miniMaxSum(arr)
