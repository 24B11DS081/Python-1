class Solution:
    def findMinHeightTrees(self, n: int, edges: List[List[int]]) -> List[int]:
        queue = deque()
        neighbors = {}
        degree = [0] * n
        if n == 1:
            return [0]

        for x, y in edges:
            if x in neighbors:
                neighbors[x].append(y)
            else:
                neighbors[x] = [y]
            degree[x] += 1

            if y in neighbors:
                neighbors[y].append(x)
            else:
                neighbors[y] = [x]
            degree[y] += 1

        for i in range(n):
            if degree[i] == 1:
                queue.append(i)

        while queue:
            size = len(queue)
            if n <= 2:
                break
            for _ in range(size):
                node = queue.popleft()
                for next_node in neighbors.get(node, []):
                    degree[next_node] -= 1
                    if degree[next_node] == 1:
                        queue.append(next_node)
            n -= size
        return [i for i in queue]
