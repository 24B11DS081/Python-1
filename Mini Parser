class Solution:
    def deserialize(self, s: str) -> NestedInteger:
        return self._deserialize(s, 0, len(s) - 1)

    def _deserialize(self, s: str, i, j) -> NestedInteger:
        if s[i] != "[":  # scalar
            return NestedInteger(int(s[i:j+1]))

        res = NestedInteger()
        if j == i + 1:  # empty list
            return res

        start = idx = i + 1  # indices for elements
        count = 0  # count the brackets
        while idx <= j:
            if count == 0 and (s[idx] == "," or s[idx] == "]"):  # end of 1 element
                res.add(self._deserialize(s, start, idx - 1))  # recursively parse the element
                start = idx + 1
            elif s[idx] == "[":  # start of another nested list
                count += 1
            elif s[idx] == "]":  # end of 1 nested list
                count -= 1
            idx += 1
        return res
