
class Solution:
    def pathSum(self, root: Optional[TreeNode], targetSum: int) -> int:

        def count_from(node,curr_sum):
            if not node:
                return 0

            curr_sum += node.val
            count = 1 if curr_sum == targetSum else 0

            count += count_from(node.left,curr_sum)
            count += count_from(node.right,curr_sum)

            return count

        if not root:
            return 0

        return (
            count_from(root,0) +
            self.pathSum(root.left,targetSum)+
            self.pathSum(root.right,targetSum)
        )
