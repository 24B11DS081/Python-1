import math
import os
import random
import re
import sys

#
# Complete the 'repeatedString' function below.
#
# The function is expected to return a LONG_INTEGER.
# The function accepts following parameters:
#  1. STRING s
#  2. LONG_INTEGER n
#

def repeatedString(s, n):
    # Step 1: Count 'a' in the original string s
    count_in_s = s.count('a')
    
    # Step 2: How many full times does s repeat in n?
    full_repeats = n // len(s)
    
    # Step 3: How many characters are left over at the end?
    remainder_len = n % len(s)
    
    # Step 4: Calculate total 'a's
    # (Full repeats * count in s) + count in the leftover prefix
    total_a = (full_repeats * count_in_s) + s[:remainder_len].count('a')
    
    return total_a

if __name__ == '__main__':
    fptr = open(os.environ['OUTPUT_PATH'], 'w')

    s = input()

    n = int(input().strip())

    result = repeatedString(s, n)

    fptr.write(str(result) + '\n')

    fptr.close()
